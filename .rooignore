# ====================================================================
# Roo Code Workspace Protection Ignore File
# Tailored for Site-Wide Refactoring & Cleanup
# ====================================================================

# 1. Block massive text/JSON dependency graphs
package-lock.json
yarn.lock
pnpm-lock.yaml
bun.lockb

# 2. Block compiled/build outputs and environments
node_modules/
dist/
build/
out/
coverage/
.env*
!.env.example

# 3. Block media and large static assets
*.png
*.jpg
*.jpeg
*.webp
*.gif
*.svg
*.ico
*.pdf
*.txt
*.xml

public/images/
public/docs/

# 4. Strict Content Guardrails (CRITICAL FOR CLEANUP)
src/content/base/
src/content/services/

# 5. Block OS metadata, caches, and non-JS scripts
.DS_Store
Thumbs.db
desktop.ini
*.log
*.py
.git/
.github/
.vscode/
.cursor/